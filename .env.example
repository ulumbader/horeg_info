NODE_ENV="development"
# Supabase transaction pooler / POSTGRES_PRISMA_URL untuk runtime aplikasi.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Supabase direct/non-pooling / POSTGRES_URL_NON_POOLING untuk Prisma Migrate.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST:5432/postgres?sslmode=require"
# Wajib berupa database/schema test terisolasi; jangan arahkan ke production.
TEST_DATABASE_URL=""
TEST_DIRECT_URL=""
# Wajib berupa database/schema E2E terisolasi; jangan arahkan ke production.
E2E_DATABASE_URL=""
E2E_DIRECT_URL=""
# Hanya dipakai sekali oleh `npm run db:transfer:sqlite`.
SQLITE_SOURCE_PATH="./prisma/dev.db"
# Isi YES hanya saat siap menyalin snapshot SQLite ke PostgreSQL target.
CONFIRM_SQLITE_TO_POSTGRES_MIGRATION=""
BETTER_AUTH_SECRET="replace-with-at-least-32-random-characters"
# Opsional tetapi direkomendasikan agar identitas anonim terpisah dari secret auth.
# Jika kosong, server memakai BETTER_AUTH_SECRET sebagai fallback.
ANONYMOUS_ID_SECRET="replace-with-another-at-least-32-random-characters"
BETTER_AUTH_URL="http://localhost:3000"
TRUSTED_ORIGINS="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_MAP_TILE_URL="https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png"
NEXT_PUBLIC_MAP_ATTRIBUTION="&copy; OpenStreetMap contributors"
# Server-only. Default memakai Nominatim publik untuk pencarian eksplisit admin.
GEOCODING_BASE_URL="https://nominatim.openstreetmap.org"
# Identitas aplikasi yang valid untuk provider geocoding; sertakan kontak operasional.
GEOCODING_USER_AGENT="SoundHoregEWS/1.0 (contact@example.com)"
ADMIN_BOOTSTRAP_EMAIL="admin@example.com"
ADMIN_BOOTSTRAP_NAME="Administrator"
ADMIN_BOOTSTRAP_PASSWORD="remove-after-successful-bootstrap"
